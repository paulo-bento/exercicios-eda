import java.util.Arrays;

public class Exercicio1<T> {

    private T[] documento;
    private T[] npaginas;
    private int tamanho;
    private int capacidade;

    public Exercicio1(int capacidade) {
        this.capacidade = capacidade;
        this.documento = (T[]) new Object[capacidade];
        this.npaginas = (T[]) new Object[capacidade];
        this.tamanho = 0;
    }

    public boolean estaVazia() {
        return tamanho == 0;
    }

    public boolean estaCheia() {
        return tamanho == capacidade;
    }

    public void enfileirar(T documento, T npaginas) {
        if (estaCheia()) {
            System.out.println("Fila cheia!");
            return;
        }
        this.documento[tamanho] = documento;
        this.npaginas[tamanho] = npaginas;
        tamanho++;
    }

    public T desenfileirar() {
        if (estaVazia()) {
            System.out.println("Fila vazia!");
            return null;
        }

        T removido = documento[0];

        for (int i = 0; i < tamanho - 1; i++) {
            documento[i] = documento[i + 1];
            npaginas[i] = npaginas[i + 1];
        }

        documento[tamanho - 1] = null;
        npaginas[tamanho - 1] = null;
        tamanho--;

        return removido;
    }

    public T peek() {
        if (estaVazia()) return null;
        return documento[0];
    }

    @Override
    public String toString() {
        return "Exercicio1{" +
                "documento=" + Arrays.toString(documento) +
                ", npaginas=" + Arrays.toString(npaginas) +
                '}';
    }

    public static void main(String[] args) {
        Exercicio1<Integer> exercicio1 = new Exercicio1<>(5);

        exercicio1.enfileirar(1, 2);
        exercicio1.enfileirar(2, 2);
        exercicio1.enfileirar(3, 5);
        exercicio1.enfileirar(4, 1);
        exercicio1.enfileirar(5, 3);

        System.out.println(exercicio1);

        exercicio1.desenfileirar();

        System.out.println(exercicio1.peek());
    }
}
